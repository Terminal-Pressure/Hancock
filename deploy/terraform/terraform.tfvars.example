# Example terraform.tfvars — copy to terraform.tfvars and fill in real values
# NEVER commit terraform.tfvars with real secrets to version control

aws_region  = "us-east-1"
project     = "hancock"
environment = "prod"

# ECR repository URL for the application image
ecr_repository_url = "123456789012.dkr.ecr.us-east-1.amazonaws.com/hancock"

# Task resources
task_cpu    = 512
task_memory = 1024

desired_count = 2
min_capacity  = 1
max_capacity  = 10

# Networking
vpc_cidr = "10.0.0.0/16"

# Secrets
nvidia_api_key_arn = "arn:aws:secretsmanager:us-east-1:123456789012:secret:nvidia/api-key-abcdef"
