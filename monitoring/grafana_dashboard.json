{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "id": null,
  "uid": "hancock-overview-v1",
  "title": "Hancock \u2014 Security AI Agent",
  "tags": [
    "hancock",
    "security",
    "ai"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": "Prometheus",
      "description": "Incoming request rate (all endpoints).",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list"
        }
      },
      "targets": [
        {
          "expr": "rate(hancock_requests_total[2m])",
          "legendFormat": "total",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": "Prometheus",
      "description": "Percentage of errors over total requests.",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list"
        }
      },
      "targets": [
        {
          "expr": "rate(hancock_errors_total[2m]) / (rate(hancock_requests_total[2m]) > 0) * 100",
          "legendFormat": "error %",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 3,
      "title": "Requests by Endpoint",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": "Prometheus",
      "description": "Cumulative request count per endpoint.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list"
        }
      },
      "targets": [
        {
          "expr": "hancock_requests_by_endpoint",
          "legendFormat": "{{endpoint}}",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 4,
      "title": "Requests by Mode",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": "Prometheus",
      "description": "Cumulative request count per specialist mode.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list"
        }
      },
      "targets": [
        {
          "expr": "hancock_requests_by_mode",
          "legendFormat": "{{mode}}",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 5,
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "datasource": "Prometheus",
      "description": "Resident set size of the Hancock process. Available when metrics_exporter is wired into the agent.",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list"
        }
      },
      "targets": [
        {
          "expr": "hancock_memory_usage_bytes",
          "legendFormat": "RSS",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 6,
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "datasource": "Prometheus",
      "description": "Current number of open HTTP connections. Available when metrics_exporter is wired into the agent.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list"
        }
      },
      "targets": [
        {
          "expr": "hancock_active_connections",
          "legendFormat": "connections",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 7,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 6,
        "h": 4
      },
      "datasource": "Prometheus",
      "description": "",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "hancock_requests_total",
          "legendFormat": "total",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 8,
      "title": "Total Errors",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 24,
        "w": 6,
        "h": 4
      },
      "datasource": "Prometheus",
      "description": "",
