      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "hancock_errors_total",
          "legendFormat": "errors",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
