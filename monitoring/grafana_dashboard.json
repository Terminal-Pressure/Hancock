        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "hancock_memory_usage_bytes",
          "legendFormat": "RSS",
          "refId": "A",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 10,
      "title": "Active Connections",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 24,
        "w": 6,
        "h": 4
      },
      "datasource": "Prometheus",
      "description": "",
      "fieldConfig": {
        "defaults": {
